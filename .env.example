# LLM Wiki — environment configuration
# Copy to .env and fill in your values

# LLM Backend (OpenAI-compatible)
LLM_WIKI_LLM_BASE_URL=https://api.openai.com/v1
LLM_WIKI_LLM_API_KEY=sk-...
LLM_WIKI_LLM_MODEL=gpt-4o-mini
LLM_WIKI_LLM_TEMPERATURE=0.2
LLM_WIKI_LLM_MAX_TOKENS=4096
# LLM_WIKI_LLM_TIMEOUT=120           # HTTP timeout in seconds (default 120)
# LLM_WIKI_LLM_NUM_GPU=0             # Ollama: GPU layers (0 = all, ignored by cloud APIs)
# LLM_WIKI_LLM_NUM_CTX=4096          # Ollama: context window size

# Local LLM example (Ollama):
# LLM_WIKI_LLM_BASE_URL=http://localhost:11434/v1
# LLM_WIKI_LLM_API_KEY=ollama
# LLM_WIKI_LLM_MODEL=llama3.1

# Vault location (defaults to ./vault relative to cwd)
LLM_WIKI_VAULT_PATH=vault

# RAG — Embedding model (leave empty to disable RAG)
# LLM_WIKI_EMBED_BASE_URL=http://localhost:11434/v1   # defaults to llm_base_url if empty
# LLM_WIKI_EMBED_API_KEY=ollama                       # defaults to llm_api_key if empty
# LLM_WIKI_EMBED_MODEL=qwen3-embedding                # Qwen / nomic-embed-text / text-embedding-ada-002
# LLM_WIKI_RERANK_MODEL=qwen3-reranker                # optional reranker (empty = cosine similarity only)
# LLM_WIKI_RERANK_BASE_URL=                           # defaults to embed_base_url if empty
# LLM_WIKI_EMBED_BATCH_SIZE=32                        # chunks per embedding API call (lower = less VRAM)
# LLM_WIKI_EMBED_NUM_GPU=0                            # Ollama: GPU layers for embed model (0 = all)
# LLM_WIKI_CHUNK_SIZE=800                             # chars per chunk
# LLM_WIKI_CHUNK_OVERLAP=150                          # overlap between chunks
# LLM_WIKI_RAG_TOP_K=5                                # chunks returned per query

# Behavior flags
LLM_WIKI_DRY_RUN=false
LLM_WIKI_VERBOSE=false
